  <property name="styleSheet">
   <string notr="true">/* ---------- General Widget Styling ---------- */
QWidget {
    background-color: #1e1e2f;
    color: #dcdcdc;
    font-family: Consolas, monospace;
    font-size: 12pt;
}

/* ---------- Group Boxes ---------- */
QGroupBox {
    border: 1px solid #3c3f58;
    border-radius: 5px;
    margin-top: 10px;
}

QGroupBox:title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 8px;
    color: #f0742f;
    font-weight: bold;
    font-size: 11pt;
}

/* ---------- Labels ---------- */
QLabel {
    color: #b9b9bb;
    background: transparent;
}
QComboBox::down-arrow {
    width: 0;
    height: 0;
    border-left: 6px solid transparent;
    border-right: 6px solid transparent;
    border-top: 6px solid white;
}
/* ---------- Line Edits (Input Fields) ---------- */
QLineEdit {
    background-color: #2c2f45;
    color: #ffffff;
    border: 2px solid #f0742f;
    border-radius: 4px;
    padding: 6px;
}

/* ---------- Combo Boxes ---------- */
QComboBox {
    background-color: #2c2f45;
    color: #ffffff;
    border: 2px solid #f0742f;
    border-radius: 4px;
    padding: 4px;
    min-width: 6em;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 20px;
    border-left: 1px solid #f0742f;
}


/* ---------- Buttons ---------- */
QPushButton {
    background-color: #f0742f;
    color: #ffffff;
    font-weight: bold;
    border: none;
    border-radius: 5px;
    padding: 8px 16px;
}

QPushButton:hover {
    background-color: #fc7c11;
}

QPushButton:pressed {
    background-color: #ff6b35;
}

/* ---------- Checkboxes ---------- */
QCheckBox {
    color: #b9b9bb;
    font-weight: normal;
}

QCheckBox::indicator {
    width: 14px;
    height: 14px;
    border: 1px solid #f0742f;
    background-color: #1e1e2f;
}

QCheckBox::indicator:checked {
    image: url(:/icons/check.png); /* Replace with a checkmark icon if desired */
    background-color: #3c3f58;
}

/* ---------- Tool Buttons ---------- */
QToolButton {
    background-color: #2c2f45;
    color: #dcdcdc;
    border: 1px solid #3c3f58;
    border-radius: 4px;
    padding: 4px 8px;
}

QToolButton:hover {
    background-color: #3c3f58;
}

/* ---------- Scroll Bars ---------- */
QScrollBar:vertical {
    border: none;
    background: #2c2f45;
    width: 10px;
    margin: 0px 0px 0px 0px;
}

QScrollBar::handle:vertical {
    background: #f0742f;
    border-radius: 5px;
    min-height: 20px;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}

/* ---------- Text Edits (for output/monitor window) ---------- */
QTextEdit, QPlainTextEdit {
    background-color: #1e1e2f;
    color: #00ff9c; /* terminal-like output */
    border: 1px solid #3c3f58;
    border-radius: 4px;
    padding: 6px;
    font-family: Consolas, monospace;
    font-size: 11pt;
}
</string>
