  <property name="styleSheet">
   <string notr="true">/* ---------- Base ---------- */
QWidget {
    background-color: #1e1e1e;
    color: #d4d4d4;
    font-family: Consolas, monospace;
    font-size: 11pt;
}

/* ---------- Panels / Containers ---------- */
QGroupBox {
    border: 1px solid #2d2d2d;
    border-radius: 4px;
    margin-top: 10px;
    padding-top: 8px;
}

QGroupBox:title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 6px;
    color: #cccccc;
}

/* ---------- Labels ---------- */
QLabel {
    color: #cccccc;
    background: transparent;
}

/* ---------- Inputs ---------- */
QLineEdit, QComboBox {
    background-color: #252526;
    color: #d4d4d4;
    border: 1px solid #3c3c3c;
    border-radius: 3px;
    padding: 5px;
}

/* Focus = VS Code blue */
QLineEdit:focus, QComboBox:focus {
    border: 1px solid #007acc;
}

/* Disabled */
QLineEdit:disabled, QComboBox:disabled {
    background-color: #2a2a2a;
    color: #777;
}

/* ---------- ComboBox ---------- */
QComboBox {
    padding-right: 18px;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 16px;
    border-left: 1px solid #3c3c3c;
}

/* Native arrow (no custom image) */
QComboBox::down-arrow {
    width: 0;
    height: 0;
}

/* Dropdown list */
QComboBox QAbstractItemView {
    background-color: #252526;
    border: 1px solid #3c3c3c;
    selection-background-color: #094771;
    selection-color: #ffffff;
}

/* ---------- Buttons ---------- */
QPushButton {
    background-color: #0e639c;
    color: #ffffff;
    border-radius: 3px;
    padding: 5px 12px;
}

QPushButton:hover {
    background-color: #1177bb;
}

QPushButton:pressed {
    background-color: #0b578a;
}

QPushButton:disabled {
    background-color: #3c3c3c;
    color: #888;
}

/* ---------- Tool Buttons ---------- */
QToolButton {
    background-color: transparent;
    color: #cccccc;
    border-radius: 3px;
    padding: 4px 6px;
}

QToolButton:hover {
    background-color: #2a2d2e;
}

QToolButton:pressed {
    background-color: #373737;
}

/* ---------- Checkboxes ---------- */
QCheckBox {
    color: #cccccc;
}

QCheckBox::indicator {
    width: 14px;
    height: 14px;
    border: 1px solid #3c3c3c;
    background-color: #1e1e1e;
}

QCheckBox::indicator:checked {
    background-color: #007acc;
}

/* ---------- Scrollbars ---------- */
QScrollBar:vertical {
    background: #1e1e1e;
    width: 10px;
}

QScrollBar::handle:vertical {
    background: #424242;
    border-radius: 5px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background: #4f4f4f;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0;
}

/* ---------- Text Editors ---------- */
QTextEdit, QPlainTextEdit {
    background-color: #1e1e1e;
    color: #d4d4d4;
    border: none;
    padding: 6px;
    selection-background-color: #264f78;
    selection-color: #ffffff;
}

/* ---------- Menus ---------- */
QMenu {
    background-color: #252526;
    border: 1px solid #3c3c3c;
}

QMenu::item {
    padding: 5px 20px;
    color: #d4d4d4;
}

QMenu::item:selected {
    background-color: #094771;
}

/* ---------- Status Bar ---------- */
QStatusBar {
    background-color: #007acc;
    color: #ffffff;
}</string>
